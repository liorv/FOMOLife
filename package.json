{
  "name": "fomo-life",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.6",
  "dependencies": {
    "@myorg/api-client": "workspace:*",
    "@myorg/types": "workspace:*",
    "@myorg/utils": "workspace:*",
    "@supabase/supabase-js": "^2.97.0",
    "jsonwebtoken": "^9.0.3",
    "next": "latest",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "scripts": {
    "dev": "pnpm run dev:mono",
    "build": "next build",
    "start": "next start",
    "setup:githooks": "git config core.hooksPath .githooks",
    "check:large-files": "node scripts/guard-large-files.js repo",
    "dev:mono": "turbo dev --filter=framework --filter=contacts --filter=projects --filter=tasks",
    "build:mono": "turbo build --filter=./apps/* --filter=./packages/*",
    "lint:mono": "turbo lint --filter=./apps/*",
    "test:mono": "turbo test",
    "typecheck:mono": "turbo typecheck --filter=./apps/* --filter=./packages/*",
    "verify-assets": "node scripts/verify-assets.js",
    "verify-logo": "node scripts/check-logo.js",
    "verify-logo-dom": "node scripts/check-logo-dom.js",
    "find-imgs": "node scripts/find-imgs.js",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "deploy:all": "powershell -ExecutionPolicy Bypass -File .\\deploy.ps1",
    "deploy:all:force": "powershell -ExecutionPolicy Bypass -File .\\deploy.ps1 -Force",
    "deploy:contacts": "powershell -ExecutionPolicy Bypass -File .\\deploy.ps1 -App contacts",
    "deploy:framework": "powershell -ExecutionPolicy Bypass -File .\\deploy.ps1 -App framework",
    "deploy:projects": "powershell -ExecutionPolicy Bypass -File .\\deploy.ps1 -App projects",
    "deploy:tasks": "powershell -ExecutionPolicy Bypass -File .\\deploy.ps1 -App tasks"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.34.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.4.6",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  }
}
