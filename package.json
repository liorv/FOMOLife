{
  "name": "fomo-life",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.6",
  "dependencies": {
    "@myorg/api-client": "workspace:*",
    "@myorg/types": "workspace:*",
    "@myorg/utils": "workspace:*",
    "@supabase/supabase-js": "^2.97.0",
    "jsonwebtoken": "^9.0.3",
    "next": "latest",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@myorg/storage": "workspace:*",
    "@myorg/ui": "workspace:*"
  },
  "scripts": {
    "dev": "next dev --port 3001 --hostname 0.0.0.0",
    "build": "echo '{\"version\":\"'$(date -u +'%Y-%m-%dT%H:%M:%SZ')'\"}' > version.json && pnpm --filter @myorg/types build && pnpm --filter @myorg/api-client build && pnpm --filter @myorg/utils build && pnpm --filter @myorg/ui build && next build",
    "start": "next start --port 3001",
    "setup:githooks": "git config core.hooksPath .githooks",
    "check:large-files": "node scripts/guard-large-files.js repo",
    "verify-assets": "node scripts/verify-assets.js",
    "verify-logo": "node scripts/check-logo.js",
    "verify-logo-dom": "node scripts/check-logo-dom.js",
    "find-imgs": "node scripts/find-imgs.js",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "deploy": "bash deploy.sh",
    "lint:app": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:app": "jest",
    "typecheck:app": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.34.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.4.6",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "identity-obj-proxy": "^3.0.0"
  }
}