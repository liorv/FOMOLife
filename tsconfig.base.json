{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@myorg/api-client": ["./packages/api-client/dist/src"],
      "@myorg/api-client/*": ["./packages/api-client/dist/src/*"],
      "@myorg/types": ["./packages/types/dist"],
      "@myorg/types/*": ["./packages/types/dist/*"],
      "@myorg/ui": ["./packages/ui/dist"],
      "@myorg/ui/*": ["./packages/ui/dist/*"],
      "@myorg/utils": ["./packages/utils/dist"],
      "@myorg/utils/*": ["./packages/utils/dist/*"],
      "@myorg/storage": ["./packages/storage/dist"],
      "@myorg/storage/*": ["./packages/storage/dist/*"],
      "@myorg/storage-client": ["./packages/storage-client/dist"],
      "@myorg/storage-client/*": ["./packages/storage-client/dist/*"]
    }
  }
}
