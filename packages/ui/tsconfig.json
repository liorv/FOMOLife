{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["react", "react-dom", "jest", "@testing-library/jest-dom"],
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": false,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["src/**/__tests__/**", "__tests__/**"],
  "references": [
    {"path": "../api-client"},
    {"path": "../types"},
    {"path": "../utils"}
  ]
}