{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": "../../",
    "paths": {
      "@myorg/api-client": ["packages/api-client/dist"],
      "@myorg/api-client/*": ["packages/api-client/dist/*"],
      "@myorg/types": ["packages/types/dist"],
      "@myorg/types/*": ["packages/types/dist/*"],
      "@myorg/utils": ["packages/utils/dist"],
      "@myorg/utils/*": ["packages/utils/dist/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["react", "react-dom"],
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": false,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["src/**/__tests__/**", "__tests__/**"]
}