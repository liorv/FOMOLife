{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // include tests in compilation to avoid rootDir errors
    "rootDir": ".",
    "outDir": "dist",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "jest"],
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts"],
  "exclude": []
}
