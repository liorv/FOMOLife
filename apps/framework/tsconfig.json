{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "react", "react-dom", "jest"],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@myorg/ui": ["../../packages/ui/src"],
      "@myorg/ui/*": ["../../packages/ui/src/*"],
      "@myorg/api-client": ["../../packages/api-client/src"],
      "@myorg/api-client/*": ["../../packages/api-client/src/*"],
      "@myorg/storage": ["../../packages/storage/src"],
      "@myorg/storage/*": ["../../packages/storage/src/*"],
      "@myorg/storage-client": ["../../packages/storage-client/src"],
      "@myorg/storage-client/*": ["../../packages/storage-client/src/*"],
      "@myorg/utils": ["../../packages/utils/src"],
      "@myorg/utils/*": ["../../packages/utils/src/*"],
      "@myorg/types": ["../../packages/types/src"],
      "@myorg/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.js", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}