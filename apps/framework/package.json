{
  "name": "framework",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "echo '{\"version\":\"'$(date -u +'%Y-%m-%dT%H:%M:%SZ')'\"}' > version.json && pnpm --filter @myorg/types build && pnpm --filter @myorg/api-client build && pnpm --filter @myorg/utils build && pnpm --filter @myorg/ui build && next build",
    "start": "next start --port 3001",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\"",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "latest",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@myorg/ui": "workspace:*",
    "@myorg/api-client": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}